{
  "$name": "@athena/ui Design Tokens",
  "$description": "Machine-readable token manifest for the Athena Health Suite. Feeds Figma Variables (light/dark modes), React theming (CSS custom properties) and the named icon registry (athena-icons.js) from one source. Tiers: primitive -> semantic -> component. Every clinical status carries a color + shape + icon + label so severity is never conveyed by colour alone (the grayscale test).",
  "$version": "2.0.0",

  "primitive": {
    "neutral": {
      "0": "#ffffff",
      "50": "#f6f7f9",
      "100": "#eceff3",
      "200": "#d8dde3",
      "300": "#cfd5dd",
      "400": "#9aa4b1",
      "500": "#6b7684",
      "600": "#4d5866",
      "700": "#3d4653",
      "800": "#1c232c",
      "900": "#12161c",
      "950": "#0d1116"
    },
    "teal": {
      "50": "#e4f2f3",
      "100": "#c2e4e7",
      "200": "#94d2d8",
      "300": "#5fbec6",
      "400": "#35b3bb",
      "500": "#14929b",
      "600": "#0e7c86",
      "700": "#0a626b",
      "800": "#0a4e55",
      "900": "#093f45"
    },
    "red": "#c22f2f",
    "red-bright": "#e05a52",
    "amber": "#d98c1a",
    "amber-bright": "#e0a13a",
    "orange": "#d1730c",
    "blue": "#4a90d9",
    "blue-deep": "#2765a8",
    "green": "#1f8a54",
    "green-bright": "#35b06f"
  },

  "severity": {
    "critical": {
      "token": "color-alert-critical",
      "label": "Critical",
      "color": "#c22f2f",
      "icon": "sev-critical",
      "shape": "octagon",
      "treatment": "solid"
    },
    "advisory": {
      "token": "color-alert-advisory",
      "label": "Advisory",
      "color": "#d98c1a",
      "icon": "sev-advisory",
      "shape": "triangle",
      "treatment": "solid"
    },
    "info": {
      "token": "color-alert-info",
      "label": "Info",
      "color": "#4a90d9",
      "icon": "sev-info",
      "shape": "circle",
      "treatment": "outlined"
    },
    "stale": {
      "token": "color-status-stale",
      "label": "Stale",
      "color": "#d1730c",
      "icon": "triangle-filled",
      "shape": "square",
      "treatment": "dashed"
    }
  },

  "dataStatus": {
    "preliminary": {
      "token": "color-status-preliminary",
      "label": "Unconfirmed",
      "color": "#4a90d9",
      "icon": "dot"
    },
    "final": {
      "token": "color-status-final",
      "label": "(no badge — expected)",
      "color": "#1a1f26",
      "icon": null
    },
    "live": {
      "token": "color-status-live",
      "label": "Live",
      "color": "#1f8a54",
      "icon": "dot-pulse"
    },
    "stale": {
      "token": "color-status-stale",
      "label": "Last updated {time}",
      "color": "#d1730c",
      "icon": "triangle-filled"
    },
    "disconnected": {
      "token": "color-status-disconnected",
      "label": "No signal",
      "color": "#9aa4b1",
      "icon": "dot"
    },
    "error": {
      "token": "color-status-error",
      "label": "Entered in error",
      "color": "#b98a86",
      "icon": "strikethrough"
    }
  },

  "theme": {
    "light": {
      "bg": "#e7eaee",
      "card": "#ffffff",
      "surface": "#ffffff",
      "surface-2": "#f6f7f9",
      "surface-3": "#eceff3",
      "border": "#d8dde3",
      "border-strong": "#cfd5dd",
      "text": "#1a1f26",
      "text-muted": "#4d5866",
      "text-subtle": "#7a8493",
      "inverse": "#12161c",
      "accent": "#0e7c86",
      "accent-strong": "#0a626b",
      "accent-soft": "#e4f2f3",
      "crit-fg": "#a8261f",
      "crit-tint": "#fbeceb",
      "crit-line": "#f0c9c6",
      "adv-fg": "#9a6a08",
      "adv-tint": "#fbf3e0",
      "adv-line": "#edd2ab",
      "info-fg": "#2765a8",
      "info-tint": "#e9f1fb",
      "info-line": "#bcd3fb",
      "stale-fg": "#a25a08",
      "stale-tint": "#fbeeda",
      "stale-line": "#edd2ab",
      "live-fg": "#17724a",
      "live-tint": "#e6f4ec",
      "live-line": "#1f8a54",
      "disc": "#9aa4b1",
      "err-fg": "#a8261f",
      "err-tint": "#fbeceb"
    },
    "dark": {
      "bg": "#0d1116",
      "card": "#161b22",
      "surface": "#161b22",
      "surface-2": "#1c232c",
      "surface-3": "#222c31",
      "border": "#2a323d",
      "border-strong": "#39434f",
      "text": "#e8ecf1",
      "text-muted": "#a9b3bf",
      "text-subtle": "#7b8593",
      "inverse": "#0d1116",
      "accent": "#35b3bb",
      "accent-strong": "#0e7c86",
      "accent-soft": "rgba(14,124,134,0.18)",
      "crit-fg": "#e88a84",
      "crit-tint": "rgba(224,90,82,0.15)",
      "crit-line": "#4a2a28",
      "adv-fg": "#e0a13a",
      "adv-tint": "rgba(216,140,26,0.15)",
      "adv-line": "#4a3a20",
      "info-fg": "#7ab3e8",
      "info-tint": "rgba(90,159,224,0.15)",
      "info-line": "#26406e",
      "stale-fg": "#e79a4d",
      "stale-tint": "rgba(224,138,58,0.16)",
      "stale-line": "#4a3a20",
      "live-fg": "#4fc487",
      "live-tint": "rgba(53,176,111,0.15)",
      "live-line": "#35b06f",
      "disc": "#6b7684",
      "err-fg": "#e88a84",
      "err-tint": "rgba(224,90,82,0.15)"
    }
  },

  "typography": {
    "family": {
      "sans": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
      "mono": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
    },
    "features": "tabular-nums (all clinical values align on the decimal)",
    "scale": {
      "display": { "size": 44, "weight": 650, "tracking": "-0.022em" },
      "title": { "size": 30, "weight": 640, "tracking": "-0.018em" },
      "heading": { "size": 22, "weight": 620, "tracking": "-0.01em" },
      "lead": { "size": 17, "weight": 600 },
      "body": { "size": 15, "weight": 450, "line": 1.5 },
      "label": { "size": 13, "weight": 500 },
      "mono": { "size": 12, "weight": 450, "family": "mono" }
    }
  },

  "spacing": {
    "base": 4,
    "scale": [4, 8, 12, 16, 24, 32, 48, 64, 80],
    "rowHeightProvider": 36,
    "cardPadding": 28,
    "sectionGap": 80,
    "hitTargetField": 44
  },
  "radius": { "sm": 7, "md": 9, "control": 10, "card": 14, "pill": 999 }
}
