{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node", "vitest"],
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["es2022", "dom"],
    "allowJs": true
  },
  "include": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts",
    "scripts/**/*.mjs"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
