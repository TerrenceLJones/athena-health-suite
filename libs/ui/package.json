{
  "name": "@athena/ui",
  "version": "0.0.1",
  "private": true,
  "description": "Athena design system React component library. Theme lives in @athena/design-tokens; icons in @athena/icons.",
  "main": "src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run --project=unit",
    "test-storybook": "vitest run --project=storybook",
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@athena/design-tokens": "workspace:*",
    "@athena/icons": "workspace:*",
    "radix-ui": "^1.6.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "~4.1.0",
    "chromatic": "^18.0.1"
  },
  "metadata": {
    "package_type": "shared"
  }
}
