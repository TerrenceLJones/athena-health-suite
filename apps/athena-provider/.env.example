# =====================================================
# Athena Provider WEB ENVIRONMENT VARIABLES
# =====================================================
# App: athena-provider
# Location: apps/athena-provider/
# Epic: PLATFORM-001
# =====================================================
# This file lists every environment variable required for the athena-provider app to run in a local development environment, and is intended to be used as a reference for the variables that must be set in the .env file for the app to run in a production environment. The variables listed here are required for the app to run in a local development environment, and are also required for the app to run in a production environment, unless otherwise noted.
# =====================================================

# -----------------------------------------------------
# MONITORING — Sentry (error tracking)
# -----------------------------------------------------
VITE_SENTRY_DSN= # From Sentry — see /infrastructure/setup-guides/sentry-setup.md
# NOTE: variable name/prefix may change to a framework-specific public
# prefix (e.g. NEXT_PUBLIC_SENTRY_DSN) once TDR-CW-WEB-001 selects the
# frontend framework.

# -----------------------------------------------------
# FHIR — Medplum hosted sandbox (Layer 1 real backend)
# -----------------------------------------------------
# Consumed by libs/fhir/client. See /infrastructure/setup-guides/08-medplum-fhir.md
# and docs/reference/athena-mock-backend-architecture.md (Layer 1).
VITE_FHIR_BASE_URL=https://api.medplum.com/fhir/R4 # Full FHIR R4 endpoint; the client splits it into origin + fhir/R4 path
VITE_MEDPLUM_CLIENT_ID= # Medplum app client id — never a secret. Access token is held in memory only.

# -----------------------------------------------------
# Deferred (not required at platform baseline)
# -----------------------------------------------------
# Database, Auth, Backend Hosting, and Real-Time provider variables are
# intentionally omitted — see TDR-PLATFORM-001 infrastructure_providers,
# all marked deferred_until_real_backend_required.

# -----------------------------------------------------
# See TDR-PLATFORM-001.yaml for why these providers were selected
# -----------------------------------------------------
