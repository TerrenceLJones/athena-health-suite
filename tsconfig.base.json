{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "composite": true,
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@athena/design-tokens": ["libs/design-tokens/src/index.ts"],
      "@athena/design-tokens/theme.css": ["libs/design-tokens/src/theme.css"],
      "@athena/fhir-types": ["libs/fhir/types/src/index.ts"],
      "@athena/fhir-client": ["libs/fhir/client/src/index.ts"],
      "@athena/fhir-hooks": ["libs/fhir/hooks/src/index.ts"],
      "@athena/icons": ["libs/icons/src/index.ts"],
      "@athena/ui": ["libs/ui/src/index.ts"],
      "@athena/ui/theme.css": ["libs/ui/src/theme/theme.css"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
